# Copy this file to .env and fill in real values to activate Supabase integration.
# Without these, the app runs fully on local demo data.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Edge Function endpoint for food parsing (optional — local fallback always works)
FOOD_PARSER_URL=https://your-project.supabase.co/functions/v1/food-parser

# Edge Function endpoint for AI coaching (optional; derived from SUPABASE_URL if omitted)
COACH_CHAT_URL=https://your-project.supabase.co/functions/v1/coach-chat
